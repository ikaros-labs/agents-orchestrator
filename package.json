{
  "name": "agents-orchestrator",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production bun run src/server.ts",
    "dev": "NODE_ENV=development bun --watch run src/server.ts",
    "type-check": "bunx tsc --noEmit",
    "test": "bun test",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/bun": "^1.3.11",
    "typescript": "^5.0.0"
  }
}
